# ───────────────────────────────────────────────────────────────────────────
# Bellus Proposta — variáveis de ambiente (exemplo)
# Copie este arquivo para `.env.local` e preencha os valores reais.
# NUNCA versione `.env.local`. Ele já está no .gitignore.
# ───────────────────────────────────────────────────────────────────────────

# WhatsApp comercial (somente dígitos, com DDI+DDD). Ex.: 5521981636666
NEXT_PUBLIC_WHATSAPP=5521981636666

# Nome do consultor que assina as propostas (aparece no rodapé/contato).
NEXT_PUBLIC_CONSULTANT_NAME=Thiago Rodrigues

# (Opcional) ID do Google Tag Manager para analytics. Sem PII.
# Deixe em branco para desativar. Ex.: GTM-XXXXXXX
NEXT_PUBLIC_GTM_ID=

# ───────────────────────────────────────────────────────────────────────────
# Painel admin (/admin). Seed do PROPRIETÁRIO no 1º acesso. Em dev, sem definir
# nada, o login é usuário "thiago" e senha "bellus".
# Em produção: senha forte + ADMIN_SECRET aleatório e longo (assina a sessão).
# ───────────────────────────────────────────────────────────────────────────
ADMIN_USER=thiago
ADMIN_NAME=Thiago Rodrigues
ADMIN_PASSWORD=bellus
ADMIN_SECRET=troque-por-um-segredo-aleatorio-longo

# ───────────────────────────────────────────────────────────────────────────
# Os LINKS DE CHECKOUT (Pix/cartão/sinal) NÃO ficam aqui.
# Eles são configurados por proposta, em src/data/proposals/<slug>.ts,
# no campo paymentOptions[].checkoutUrl  (veja o README).
# Isso permite um link diferente por cliente, pacote e condição de pagamento.
# ───────────────────────────────────────────────────────────────────────────
